# SDGS HIL Testbed — Environment Configuration Template
# Copy to .env and fill in your own values (never commit .env to git)
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   source .env && python3 sdgs_web_engine.py

# ── Raspberry Pi network addresses ──────────────────────────────────────────
# Pi1 = primary satellite link node (active tracking satellite)
PI1_WG_IP=10.100.0.2          # Pi1 WireGuard tunnel IP  (wg0 on Ubuntu side)
PI1_LAN_IP=192.168.1.10       # Pi1 local LAN IP         (fallback ping target)

# Pi2 = secondary satellite link node (standby / pre-warm)
PI2_LAN_IP=192.168.1.11

# ── SSH access (for OpenSN_VLM legacy mode only) ─────────────────────────────
PI_USER=pi
PI_PASS=                      # prefer SSH key auth; set only if using password auth

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1          # localhost when running on Ubuntu server
                               # or 10.100.0.1 (WireGuard IP) when running on Pi

# ── WireGuard (Pi2 side ntn_worker) ─────────────────────────────────────────
# Generate: wg genkey | tee pi2_private.key | wg pubkey > pi2_public.key
# Then paste the template from wg1_pi2.conf.example
# WG1_CONFIG is read from file by default in production; see ntn_worker.py
